#potential automation for working with pairs of ids to get like ones together
import itertools

def get_pair_combinations(pairs):
    # Convert pairs to sets to easily handle merging
    pair_sets = [set(p) for p in pairs]
    all_combinations = set()
    
    # Generate every possible combination of the pairs
    for r in range(1, len(pair_sets) + 1):
        for combo in itertools.combinations(pair_sets, r):
            # Merge all numbers in the current combination of pairs
            merged = set().union(*combo)
            # Convert to a sorted tuple so it can be added to our unique set
            all_combinations.add(tuple(sorted(merged)))
            
    # Sort the final results by size and then by number
    return sorted(list(all_combinations), key=lambda x: (len(x), x))

# --- Example Usage ---
input_pairs = [(1, 2), (1, 3)]
result = get_pair_combinations(input_pairs)

print(result)
# Output: [(1, 2), (1, 3), (1, 2, 3)]
